{
  "layer": "top",
  "position": "top",
  "height": 32,

  "modules-left": ["hyprland/workspaces", "mpris"],
  "modules-center": ["clock", "custom/weather"],
  "modules-right": ["pulseaudio", "backlight", "network", "custom/gpu", "power-profiles-daemon",  "battery", "cpu", "memory", "temperature", "tray", "custom/notification"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{name}", // Just show the number
    "on-click": "activate"
  },

  "clock": {
    "format": "’ĆŚ  {:%H:%M}",
    "tooltip-format": "¾░āŁ  {:%A, %d %B %Y}"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Ø¤",
    "format-icons": {
      "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
    },
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "’ć½  {signalStrength}%",
    "format-ethernet": "¾░łĆ  Connected",
    "format-disconnected": "¾░¢¬  Offline",
    "on-click": "nm-connection-editor"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’ā¦",
      "performance": "’ā¦",
      "balanced": "’ēÄ",
      "power-saver": "’ü¼"
    }
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "¾▒Éŗ {capacity}%",
    "format-plugged": "’ć” {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"]
  },

  "cpu": {
    "format": "’Æ╝  {usage}%",
    "on-click": "kitty -e btop"
  },

  "memory": {
    "format": "¾░Źø  {used}GiB",
    "on-click": "kitty -e btop"
  },

  "temperature": {
      "thermal-zone": 2,
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}┬░C",
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["’ŗŗ", "’ŗē", "’ŗć"],
      "on-click": "kitty -e btop"
  },

  "custom/gpu": {
      "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used --format=csv,noheader,nounits | awk -F', ' '{print $1\"% \"$2\"┬░C \"$3\"MB\"}'",
      "format": "¾░ó«  {}",
      "interval": 5,
      "on-click": "kitty -e nvtop"
  },

  "backlight": {
      "device": "intel_backlight", // Replace with your result from the command above
      "format": "{icon}  {percent}%",
      "format-icons": ["¾░ā×", "¾░ā¤", "¾░āĀ"],
      "on-scroll-up": "brightnessctl set 1%+",
      "on-scroll-down": "brightnessctl set 1%-",
      "min-length": 6
  },

  "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} <i>{dynamic}</i>",
      "player-icons": {
          "default": "Ō¢Č",
          "spotify": "’å╝"
      },
      "status-icons": {
          "paused": "’üī"
      },
      "on-click": "playerctl play-pause",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous",
      "dynamic-len": 35, // Cuts off long song titles
      "ignored-players": ["firefox"] // Prevents browser videos from taking over
  },
  "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
          "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
          "none": "’éó",
          "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
          "dnd-none": "’ćĘ",
          "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
          "inhibited-none": "’éó",
          "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
          "dnd-inhibited-none": "’ćĘ"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
  },

  "custom/weather": {
      "format": "{}┬░",
      "tooltip": true,
      "interval": 3600,
      "exec": "wttrbar",
      "return-type": "json"
  },

  "tray": {
    "spacing": 10
  }
}
