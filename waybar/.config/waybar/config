{
  "layer": "top",
  "position": "top",
  "height": 32,

  "modules-left": ["hyprland/workspaces", "privacy", "custom/weather", "mpris"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "backlight", "network", "custom/gpu", "power-profiles-daemon",  "battery", "cpu", "memory", "temperature", "tray", "custom/notification"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{name}", // Just show the number
    "on-click": "activate"
  },

  "clock": {
      "format": "ΎΑΩ  {:%H:%M  ≤░Δφ  %A, %d %B}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
          "mode": "year",
          "mode-mon-col": 3,
          "on-scroll": 1,
          "format": {
              "months": "<span color='#ffead3'><b>{}</b></span>",
              "days": "<span color='#ecc6d9'><b>{}</b></span>",
              "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
              "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
              "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
          }
      },
      "on-click": "gsimplecal"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "≤░ζθ",
    "format-icons": {
      "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
    },
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "ΎΘτ  {signalStrength}%",
    "format-ethernet": "≤░ΙΑ  Connected",
    "format-disconnected": "≤░Ψς  Offline",
    "on-click": "nm-connection-editor"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    }
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤▒ΡΜ {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
  },

  "cpu": {
    "format": "ΎΤ╝  {usage}%",
    "on-click": "kitty -e btop"
  },

  "memory": {
    "format": "≤░Ξδ  {used}GiB",
    "on-click": "kitty -e btop"
  },

  "temperature": {
      "thermal-zone": 2,
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}┬░C",
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"],
      "on-click": "kitty -e btop"
  },

  "custom/gpu": {
      "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used --format=csv,noheader,nounits | awk -F', ' '{print $1\"% \"$2\"┬░C \"$3\"MB\"}'",
      "format": "≤░λχ  {}",
      "interval": 5,
      "on-click": "kitty -e nvtop"
  },

  "backlight": {
      "device": "intel_backlight", // Replace with your result from the command above
      "format": "{icon}  {percent}%",
      "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
      "on-scroll-up": "brightnessctl set 1%+",
      "on-scroll-down": "brightnessctl set 1%-",
      "min-length": 6
  },

  "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} <i>{dynamic}</i>",
      "player-icons": {
          "default": "έΨ╢",
          "spotify": "ΎΗ╝"
      },
      "status-icons": {
          "paused": "ΎΒΝ"
      },
      "on-click": "playerctl play-pause",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous",
      "dynamic-len": 35, // Cuts off long song titles
      "ignored-players": ["firefox"] // Prevents browser videos from taking over
  },
  "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
          "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "none": "ΎΓλ",
          "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "dnd-none": "ΎΘ╖",
          "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "inhibited-none": "ΎΓλ",
          "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "dnd-inhibited-none": "ΎΘ╖"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
  },

  "custom/weather": {
      "format": "{}┬░",
      "tooltip": true,
      "interval": 3600,
      "exec": "wttrbar",
      "return-type": "json"
  },

  "privacy": {
      "icon-spacing": 4,
      "icon-size": 18,
      "ignore": [
        {
          "type": "screenshare",
          "name": "obs"
        }
      ],
      "nodes": [
          {
              "type": "audio-in",
              "tooltip": true
          },
          {
              "type": "screenshare",
              "tooltip": true
          }
      ]
  },

  "tray": {
    "spacing": 10
  }
}
