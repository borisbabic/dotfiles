{
  "layer": "top",
  "position": "top",
  "height": 32,

  "modules-left": ["hyprland/workspaces",  "custom/weather", "mpris"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "backlight", "network", "custom/gpu", "power-profiles-daemon",  "battery", "cpu", "memory", "temperature", "tray", "custom/notification"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{name}", // Just show the number
    "on-click": "activate"
  },

  "clock": {
      "format": "ï€—  {:%H:%M  َ°ƒ­  %A, %d %B}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
          "mode": "year",
          "mode-mon-col": 3,
          "on-scroll": 1,
          "format": {
              "months": "<span color='#ffead3'><b>{}</b></span>",
              "days": "<span color='#ecc6d9'><b>{}</b></span>",
              "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
              "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
              "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
          }
      },
      "on-click": "gsimplecal"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "ï‡«  {signalStrength}%",
    "format-ethernet": "َ°ˆ€  Connected",
    "format-disconnected": "َ°–ھ  Offline",
    "on-click": "nm-connection-editor"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ïƒ§",
      "performance": "ïƒ§",
      "balanced": "ï‰ژ",
      "power-saver": "ïپ¬"
    }
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ±گ‹ {capacity}%",
    "format-plugged": "ï‡¦ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },

  "cpu": {
    "format": "ï’¼  {usage}%",
    "on-click": "kitty -e btop"
  },

  "memory": {
    "format": "َ°چ›  {used}GiB",
    "on-click": "kitty -e btop"
  },

  "temperature": {
      "thermal-zone": 2,
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}آ°C",
      "format": "{icon} {temperatureC}آ°C",
      "format-icons": ["ï‹‹", "ï‹‰", "ï‹‡"],
      "on-click": "kitty -e btop"
  },

  "custom/gpu": {
      "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used --format=csv,noheader,nounits | awk -F', ' '{print $1\"% \"$2\"آ°C \"$3\"MB\"}'",
      "format": "َ°¢®  {}",
      "interval": 5,
      "on-click": "kitty -e nvtop"
  },

  "backlight": {
      "device": "intel_backlight", // Replace with your result from the command above
      "format": "{icon}  {percent}%",
      "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
      "on-scroll-up": "brightnessctl set 1%+",
      "on-scroll-down": "brightnessctl set 1%-",
      "min-length": 6
  },

  "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} <i>{dynamic}</i>",
      "player-icons": {
          "default": "â–¶",
          "spotify": "ï†¼"
      },
      "status-icons": {
          "paused": "ïپŒ"
      },
      "on-click": "playerctl play-pause",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous",
      "dynamic-len": 35, // Cuts off long song titles
      "ignored-players": ["firefox"] // Prevents browser videos from taking over
  },
  "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
          "notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
          "none": "ï‚¢",
          "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
          "dnd-none": "ï‡·",
          "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
          "inhibited-none": "ï‚¢",
          "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
          "dnd-inhibited-none": "ï‡·"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
  },

  "custom/weather": {
      "format": "{}آ°",
      "tooltip": true,
      "interval": 3600,
      "exec": "wttrbar",
      "return-type": "json"
  },

  "tray": {
    "spacing": 10
  }

}
