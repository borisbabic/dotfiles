{
  "layer": "top",
  "position": "top",
  "height": 32,

  "modules-left": ["hyprland/workspaces", "mpris"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "backlight", "network", "custom/gpu", "power-profiles-daemon",  "battery", "cpu", "memory", "temperature", "tray", "custom/notification"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{name}", // Just show the number
    "on-click": "activate"
  },

  "clock": {
    "format": "´Çù  {:%H:%M}",
    "tooltip-format": "¾░â¡  {:%A, %d %B %Y}"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Øƒ",
    "format-icons": {
      "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
    },
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "´ç½  {signalStrength}%",
    "format-ethernet": "¾░êÇ  Connected",
    "format-disconnected": "¾░û¬  Offline",
    "on-click": "nm-connection-editor"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "´âº",
      "performance": "´âº",
      "balanced": "´ëÄ",
      "power-saver": "´ü¼"
    }
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "¾▒Éï {capacity}%",
    "format-plugged": "´çª {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"]
  },

  "cpu": {
    "format": "´Æ╝  {usage}%",
    "on-click": "kitty -e btop"
  },

  "memory": {
    "format": "¾░ìø  {used}GiB",
    "on-click": "kitty -e btop"
  },

  "temperature": {
      "thermal-zone": 2,
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}┬░C",
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["´ïï", "´ïë", "´ïç"],
      "on-click": "kitty -e btop"
  },

  "custom/gpu": {
      "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used --format=csv,noheader,nounits | awk -F', ' '{print $1\"% \"$2\"┬░C \"$3\"MB\"}'",
      "format": "¾░ó«  {}",
      "interval": 5,
      "on-click": "kitty -e nvtop"
  },

  "backlight": {
      "device": "intel_backlight", // Replace with your result from the command above
      "format": "{icon}  {percent}%",
      "format-icons": ["¾░â×", "¾░âƒ", "¾░âá"],
      "on-scroll-up": "brightnessctl set 1%+",
      "on-scroll-down": "brightnessctl set 1%-",
      "min-length": 6
  },

  "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} <i>{dynamic}</i>",
      "player-icons": {
          "default": "ÔûÂ",
          "spotify": "´å╝"
      },
      "status-icons": {
          "paused": "´üî"
      },
      "on-click": "playerctl play-pause",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous",
      "dynamic-len": 35, // Cuts off long song titles
      "ignored-players": ["firefox"] // Prevents browser videos from taking over
  },
  "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
          "notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
          "none": "´éó",
          "dnd-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
          "dnd-none": "´çÀ",
          "inhibited-notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
          "inhibited-none": "´éó",
          "dnd-inhibited-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
          "dnd-inhibited-none": "´çÀ"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
  },

  "tray": {
    "spacing": 10
  }
}
